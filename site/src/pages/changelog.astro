---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { releases } from '../changelog';
import { site } from '../config';

const fmt = (iso: string) =>
  new Date(iso + 'T00:00:00').toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
---

<Layout title="Changelog" description={`Release notes and what's new in ${site.name}.`}>
  <Nav />

  <main class="log">
    <header class="log-head container">
      <span class="eyebrow">Changelog</span>
      <h1 class="section-title">What's new in {site.name}</h1>
      <p class="section-sub">Every notable change, newest first.</p>
    </header>

    <div class="container timeline">
      {
        releases.map((r) => (
          <article class="release reveal" id={`v${r.version}`}>
            <div class="meta">
              <a class="ver" href={`#v${r.version}`}>v{r.version}</a>
              <time datetime={r.date}>{fmt(r.date)}</time>
            </div>

            <div class="body glass">
              <ul>
                {r.entries.map((e) =>
                  e.tag === 'Section' ? (
                    <li class="grp">
                      <h4 set:html={e.html} />
                    </li>
                  ) : (
                    <li>
                      <span class={`tag t-${e.tag.toLowerCase()}`}>{e.tag}</span>
                      <span class="txt" set:html={e.html} />
                    </li>
                  ),
                )}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .log {
    padding-top: clamp(40px, 6vw, 72px);
  }
  .log-head {
    text-align: center;
    max-width: 680px;
    margin: 0 auto clamp(40px, 6vw, 64px);
  }
  .log-head .section-sub {
    margin-inline: auto;
  }
  .log-head a {
    color: var(--violet-bright);
    font-weight: 600;
  }
  .log-head a:hover {
    text-decoration: underline;
  }

  .timeline {
    max-width: 820px;
    padding-bottom: 40px;
  }

  .release {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 28px;
    padding-bottom: 40px;
    position: relative;
  }
  /* vertical timeline line + node */
  .release::before {
    content: '';
    position: absolute;
    left: 150px;
    top: 8px;
    bottom: -8px;
    width: 1px;
    background: var(--glass-border);
  }
  .release:last-child::before {
    display: none;
  }

  .meta {
    text-align: right;
    position: sticky;
    top: 84px;
    align-self: start;
    height: fit-content;
  }
  .ver {
    display: inline-block;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 600;
    font-size: 1rem;
    color: var(--violet-bright);
    padding: 3px 10px;
    border: 1px solid var(--glass-border);
    border-radius: 8px;
    background: var(--glass-bg);
  }
  .ver:hover {
    border-color: var(--glass-border-strong);
  }
  .meta time {
    display: block;
    margin-top: 8px;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .body {
    padding: 22px 24px;
    position: relative;
  }
  /* node dot on the line */
  .body::before {
    content: '';
    position: absolute;
    left: -33px;
    top: 26px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--violet);
    box-shadow: 0 0 0 4px var(--bg-0), 0 0 14px var(--violet);
  }
  .summary {
    font-size: 1rem;
    color: var(--text);
    margin-bottom: 16px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--glass-border);
  }
  ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  li {
    display: flex;
    gap: 12px;
    align-items: baseline;
  }
  .txt {
    color: var(--text-soft);
    font-size: 0.94rem;
  }
  .txt :global(strong) {
    color: var(--text);
    font-weight: 600;
  }
  .txt :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82em;
    padding: 1px 5px;
    border-radius: 5px;
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid var(--glass-border);
    color: var(--violet-bright);
  }
  /* Section subheading (e.g. the grouped categories in the initial release) */
  .grp {
    margin-top: 6px;
  }
  .grp h4 {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  li.grp:first-child {
    margin-top: 0;
  }

  .tag {
    flex-shrink: 0;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 6px;
    border: 1px solid currentColor;
    width: 76px;
    text-align: center;
  }
  .t-new {
    color: var(--green);
    background: color-mix(in srgb, var(--green) 12%, transparent);
  }
  .t-improved {
    color: var(--cyan);
    background: color-mix(in srgb, var(--cyan) 12%, transparent);
  }
  .t-fixed {
    color: var(--amber);
    background: color-mix(in srgb, var(--amber) 12%, transparent);
  }
  .t-security {
    color: var(--violet-bright);
    background: color-mix(in srgb, var(--violet-bright) 14%, transparent);
  }
  .t-removed {
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.05);
  }
  .t-internal {
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.04);
  }

  @media (max-width: 680px) {
    .release {
      grid-template-columns: 1fr;
      gap: 14px;
    }
    .release::before {
      display: none;
    }
    .meta {
      text-align: left;
      position: static;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .meta time {
      margin-top: 0;
    }
    .body::before {
      display: none;
    }
    li {
      flex-direction: column;
      gap: 5px;
    }
  }
</style>
