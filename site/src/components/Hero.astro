---
import { site, media } from '../config';
---

<section class="hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <a class="badge" href="/changelog">
        <span class="dot"></span> v{site.version} is out — see what's new
      </a>

      <h1>
        The terminal-first workspace that
        <span class="grad">stays out of your way</span>.
      </h1>

      <p class="lede">{site.description}</p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="#download">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3v12"/><path d="m7 11 5 5 5-5"/><path d="M5 21h14"/></svg>
          Download Soryq
        </a>
        <a class="btn btn-ghost" href="/changelog">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 3v18h18"/><path d="m7 14 4-4 3 3 5-6"/></svg>
          See what's new
        </a>
      </div>

      <ul class="hero-points">
        <li><span>⚡</span> No Electron · ~40–80 MB RAM</li>
        <li><span>⌨️</span> Keyboard-driven, single window</li>
        <li><span>🦀</span> Built on Tauri 2 (Rust) + Svelte 5</li>
        <li><span>🔑</span> Bring your own AI key · stored in your OS keychain</li>
      </ul>
    </div>

    <!-- App-window mockup mirroring Soryq's 3-pane layout -->
    <div class="mock-wrap reveal">
      <div class="mock glass">
        <div class="mock-titlebar">
          <span class="tl tl-r"></span><span class="tl tl-y"></span><span class="tl tl-g"></span>
          <span class="mock-title mono">soryq · ~/projects/app</span>
        </div>
        {
          media.screenshotReady ? (
            <img
              class="mock-shot"
              src={media.screenshot}
              alt="Soryq running with a terminal grid, code editor, and live preview"
              loading="eager"
            />
          ) : (
            <div class="mock-body">
              <div class="pane pane-term" data-term>
                <div class="term-line">
                  <span class="prompt">❯</span>
                  <span class="cmd typed" data-typed>npm run dev</span><span class="caret"></span>
                </div>
                <div class="term-out" data-out>
                  <div class="out-line">VITE ready in 312 ms</div>
                  <div class="out-line dim">➜ Local: http://localhost:5173</div>
                </div>
              </div>
              <div class="mock-cols">
                <div class="pane pane-term2">
                  <span class="prompt green">❯</span> <span class="cmd dim">git status</span>
                  <div class="line s2"></div>
                  <div class="run"><span class="dot-g"></span> running</div>
                </div>
                <div class="pane pane-code">
                  <div class="code"><span class="kw"></span><span class="t"></span></div>
                  <div class="code"><span class="fn"></span><span class="t"></span></div>
                  <div class="code"><span class="num"></span><span class="t"></span></div>
                  <div class="code"><span class="t long"></span></div>
                  <div class="code"><span class="t long"></span></div>
                </div>
              </div>
            </div>
          )
        }
      </div>
      <div class="mock-glow"></div>
    </div>
  </div>
</section>

<script>
  // Live-typing terminal in the hero mockup. Falls back to the static markup
  // (command + output already visible) when JS is off or motion is reduced.
  const term = document.querySelector<HTMLElement>('[data-term]');
  const typedEl = term?.querySelector<HTMLElement>('[data-typed]');
  const outEl = term?.querySelector<HTMLElement>('[data-out]');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (term && typedEl && outEl && !reduce) {
    const seq = [
      { cmd: 'npm run dev', out: ['VITE ready in 312 ms', '➜ Local: http://localhost:5173'] },
      { cmd: 'git commit -m "ship it"', out: ['[main 9f2c1a] ship it', '3 files changed, 48 insertions(+)'] },
      { cmd: 'cargo build --release', out: ['Compiling soryq v0.3.8', 'Finished release in 4.2s'] },
    ];
    term.classList.add('typing');
    const sleep = (ms: number) => new Promise((r) => setTimeout(r, ms));

    (async () => {
      let i = 0;
      // eslint-disable-next-line no-constant-condition
      while (true) {
        const step = seq[i % seq.length];
        typedEl.textContent = '';
        outEl.innerHTML = '';
        for (const ch of step.cmd) {
          typedEl.textContent += ch;
          await sleep(42 + Math.random() * 48);
        }
        await sleep(360);
        for (const line of step.out) {
          const div = document.createElement('div');
          div.className = 'out-line';
          if (/^➜|insertion|Finished|changed/.test(line)) div.classList.add('dim');
          div.textContent = line;
          outEl.appendChild(div);
          requestAnimationFrame(() => div.classList.add('show'));
          await sleep(240);
        }
        await sleep(2100);
        i++;
      }
    })();
  }
</script>

<style>
  .hero {
    padding-top: clamp(48px, 7vw, 90px);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 56px;
    align-items: center;
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    color: var(--text-soft);
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid var(--glass-border);
    background: var(--glass-bg);
    margin-bottom: 24px;
  }
  .badge:hover {
    border-color: var(--glass-border-strong);
    color: var(--text);
  }
  .dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 10px var(--green);
  }
  h1 {
    font-size: clamp(2.3rem, 5.2vw, 3.7rem);
    line-height: 1.05;
    letter-spacing: -0.03em;
    font-weight: 800;
  }
  .grad {
    background: linear-gradient(120deg, var(--violet-bright), var(--cyan));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .lede {
    margin-top: 22px;
    font-size: 1.12rem;
    color: var(--text-soft);
    max-width: 52ch;
  }
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 32px;
  }
  .hero-points {
    list-style: none;
    margin-top: 34px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: var(--text-soft);
    font-size: 0.95rem;
  }
  .hero-points li {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  /* ── Mockup ── */
  .mock-wrap {
    position: relative;
  }
  .mock-glow {
    position: absolute;
    inset: 10% 5%;
    z-index: -1;
    background: radial-gradient(60% 60% at 50% 40%, rgba(174, 182, 194, 0.38), transparent 70%);
    filter: blur(50px);
  }
  .mock {
    overflow: hidden;
    padding: 0;
    transform: perspective(1400px) rotateY(-9deg) rotateX(3deg);
    transform-origin: center;
  }
  .mock-titlebar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--glass-border);
    background: rgba(255, 255, 255, 0.03);
  }
  .tl {
    width: 11px;
    height: 11px;
    border-radius: 50%;
  }
  .tl-r { background: #ff5f57; }
  .tl-y { background: #febc2e; }
  .tl-g { background: #28c840; }
  .mock-title {
    margin-left: 12px;
    font-size: 0.72rem;
    color: var(--text-muted);
  }
  .mock-shot {
    display: block;
    width: 100%;
    height: auto;
  }
  .mock-body {
    padding: 14px;
    display: grid;
    gap: 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.74rem;
  }
  .pane {
    border: 1px solid var(--glass-border);
    border-radius: 10px;
    padding: 12px;
    background: rgba(0, 0, 0, 0.25);
  }
  .pane-term { min-height: 86px; }
  .term-line {
    display: flex;
    align-items: center;
    gap: 7px;
  }
  .term-line .caret {
    margin: 0;
    flex-shrink: 0;
  }
  .typed {
    white-space: pre;
  }
  .term-out {
    margin-top: 9px;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .out-line {
    color: var(--text-soft);
    opacity: 0;
    transform: translateY(2px);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }
  .out-line.show {
    opacity: 1;
    transform: none;
  }
  .out-line.dim {
    color: var(--text-muted);
  }
  /* Static (no-JS / reduced-motion) fallback: output is simply visible */
  .term-out .out-line {
    opacity: 1;
    transform: none;
  }
  [data-term].typing .term-out .out-line {
    opacity: 0;
    transform: translateY(2px);
  }
  [data-term].typing .term-out .out-line.show {
    opacity: 1;
    transform: none;
  }
  .mock-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }
  .pane-term2,
  .pane-code { min-height: 130px; }
  .prompt { color: var(--violet); font-weight: 600; }
  .prompt.green { color: var(--green); }
  .cmd { color: var(--text); }
  .cmd.dim { color: var(--text-soft); }
  .line {
    height: 6px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.12);
    margin-top: 10px;
  }
  .line.s1 { width: 70%; }
  .line.s2 { width: 45%; background: rgba(255, 255, 255, 0.08); }
  .caret {
    display: inline-block;
    width: 7px;
    height: 13px;
    margin-top: 10px;
    background: var(--violet);
    border-radius: 2px;
    animation: blink 1.1s step-end infinite;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }
  .run {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-top: 12px;
    color: var(--text-soft);
  }
  .dot-g {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 8px var(--green);
  }
  .code {
    display: flex;
    gap: 6px;
    margin-bottom: 8px;
  }
  .code span {
    height: 6px;
    border-radius: 3px;
  }
  .kw { width: 22px; background: var(--violet); }
  .fn { width: 16px; background: var(--green); }
  .num { width: 18px; background: var(--sky); }
  .t { width: 60px; background: rgba(255, 255, 255, 0.25); }
  .t.long { width: 88px; background: rgba(255, 255, 255, 0.13); }

  @media (max-width: 920px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .mock {
      transform: none;
      max-width: 520px;
      margin-inline: auto;
    }
  }
</style>
