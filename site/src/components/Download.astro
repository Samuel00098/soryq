---
import { downloads, downloadsAvailable, site } from '../config';

const icons: Record<string, string> = {
  windows:
    '<path d="M3 5.5 10 4.5v7H3zM10 4.3 21 3v8.5H10zM3 12.5h7v7l-7-1zM10 12.5h11V21l-11-1.5z"/>',
  apple:
    '<path d="M16.4 12.6c0-2.3 1.9-3.4 2-3.5-1.1-1.6-2.8-1.8-3.4-1.9-1.4-.1-2.8.9-3.5.9s-1.8-.9-3-.9c-1.5 0-2.9.9-3.7 2.3-1.6 2.7-.4 6.8 1.1 9 .8 1.1 1.6 2.3 2.8 2.2 1.1 0 1.6-.7 3-.7s1.8.7 3 .7 2-1.1 2.7-2.1c.9-1.2 1.2-2.4 1.2-2.5 0 0-2.3-.9-2.5-3.5zM14.3 5.8c.6-.8 1-1.8.9-2.8-.9 0-2 .6-2.6 1.3-.6.6-1.1 1.7-1 2.7 1 0 2-.5 2.7-1.2z"/>',
  linux:
    '<path d="M12 2c-2.2 0-3.5 1.8-3.5 4 0 1.4.3 2.3.3 3.4 0 1.2-1.2 2.3-2 3.8-.9 1.6-1.8 3.3-1.8 4.7 0 .8.5 1.2 1.2 1.2.5 0 .8-.3 1.2-.6.2 1 1 1.5 2 1.7.4.6 1.4 1.1 2.6 1.1s2.2-.5 2.6-1.1c1-.2 1.8-.7 2-1.7.4.3.7.6 1.2.6.7 0 1.2-.4 1.2-1.2 0-1.4-.9-3.1-1.8-4.7-.8-1.5-2-2.6-2-3.8 0-1.1.3-2 .3-3.4 0-2.2-1.3-4-3.5-4z"/>',
};
---

<section id="download">
  <div class="container">
    <div class="head reveal">
      <span class="eyebrow">Download</span>
      <h2 class="section-title">Get {site.name} for your platform.</h2>
      <p class="section-sub">
        Native installers for Windows, macOS, and Linux.
        {!downloadsAvailable && ' Builds are being prepared — they’ll be available here shortly.'}
      </p>
    </div>

    <div class="grid">
      {
        downloads.map((d) => (
          <article class="card glass reveal">
            <div class="os">
              <svg width="34" height="34" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" set:html={icons[d.icon]} />
              <div>
                <h3>{d.os}</h3>
                <span class="meta">{d.note}</span>
              </div>
            </div>

            {downloadsAvailable ? (
              <a class="btn btn-primary dl" href={d.href} download>
                Download {d.file}
              </a>
            ) : (
              <span class="btn dl soon" aria-disabled="true">
                Coming soon
              </span>
            )}

            <span class="file">{d.file}</span>
          </article>
        ))
      }
    </div>

    <p class="all">Windows, macOS &amp; Linux · Signed auto-updates built in.</p>
  </div>
</section>

<style>
  .head {
    text-align: center;
    margin-inline: auto;
    max-width: 620px;
    margin-bottom: 52px;
  }
  .head .section-sub {
    margin-inline: auto;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .card {
    padding: 26px 24px;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }
  .os {
    display: flex;
    align-items: center;
    gap: 14px;
    color: var(--text);
  }
  .os h3 {
    font-size: 1.15rem;
    font-weight: 600;
  }
  .meta {
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .dl {
    justify-content: center;
    width: 100%;
  }
  .soon {
    background: var(--glass-bg-strong);
    border: 1px solid var(--glass-border);
    color: var(--text-muted);
    cursor: default;
  }
  .soon:hover {
    transform: none;
  }
  .file {
    text-align: center;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .all {
    text-align: center;
    margin-top: 32px;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  @media (max-width: 880px) {
    .grid {
      grid-template-columns: 1fr;
      max-width: 440px;
      margin-inline: auto;
    }
  }
</style>
