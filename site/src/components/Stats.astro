---
import { stats } from '../config';
---

<section class="stats-sec">
  <div class="container">
    <div class="stats glass reveal">
      {
        stats.map((s) => (
          <div class="stat">
            <span class="value">{s.value}</span>
            <span class="label">{s.label}</span>
            <span class="sub">{s.sub}</span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .stats-sec {
    padding-block: 0;
    margin-top: -20px;
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    padding: 36px 24px;
  }
  .stat {
    text-align: center;
    padding: 8px 18px;
    border-right: 1px solid var(--glass-border);
  }
  .stat:last-child {
    border-right: none;
  }
  .value {
    display: block;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(120deg, #fff, var(--violet-bright));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .label {
    display: block;
    margin-top: 6px;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text);
  }
  .sub {
    display: block;
    margin-top: 3px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  @media (max-width: 720px) {
    .stats {
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }
    .stat:nth-child(2) {
      border-right: none;
    }
    .stat:nth-child(1),
    .stat:nth-child(2) {
      border-bottom: 1px solid var(--glass-border);
      padding-bottom: 20px;
    }
    .stat:nth-child(3),
    .stat:nth-child(4) {
      padding-top: 20px;
    }
  }
</style>
