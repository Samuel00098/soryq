---
import { media } from '../config';
const hasPoster = media.screenshotReady || media.videoReady;
const poster = media.videoReady ? media.videoPoster : media.screenshot;
---

<section id="demo">
  <div class="container">
    <div class="head reveal">
      <span class="eyebrow">See it in action</span>
      <h2 class="section-title">A real workflow, start to finish.</h2>
      <p class="section-sub">
        Watch a terminal, editor, live preview, and Git move together in one window — no
        tab-hopping, no context loss.
      </p>
    </div>

    <div class="player glass reveal">
      <div class="player-glow" aria-hidden="true"></div>

      {
        media.videoReady ? (
          <video
            class="vid"
            controls
            preload="none"
            playsinline
            poster={media.videoPoster}
          >
            <source src={media.video} type="video/mp4" />
            Your browser doesn't support embedded video.
          </video>
        ) : (
          <div class="placeholder" style={hasPoster ? `background-image:url(${poster})` : ''}>
            <span class="play" aria-hidden="true">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="currentColor">
                <path d="M8 5v14l11-7z" />
              </svg>
            </span>
            <span class="soon">Demo video coming soon</span>
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .head {
    text-align: center;
    margin-inline: auto;
    max-width: 640px;
    margin-bottom: 48px;
  }
  .head .section-sub {
    margin-inline: auto;
  }
  .player {
    position: relative;
    overflow: hidden;
    padding: 14px;
    max-width: 960px;
    margin-inline: auto;
  }
  .player-glow {
    position: absolute;
    inset: -30% 10% auto;
    height: 320px;
    background: radial-gradient(50% 100% at 50% 0%, rgba(174, 182, 194, 0.28), transparent 70%);
    filter: blur(50px);
    pointer-events: none;
  }
  .vid {
    position: relative;
    display: block;
    width: 100%;
    height: auto;
    border-radius: 12px;
    aspect-ratio: 16 / 10;
    background: #000;
  }
  .placeholder {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 18px;
    aspect-ratio: 16 / 10;
    border-radius: 12px;
    background-color: rgba(0, 0, 0, 0.4);
    background-size: cover;
    background-position: center;
    border: 1px solid var(--glass-border);
  }
  .play {
    display: grid;
    place-items: center;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    color: #04201d;
    background: linear-gradient(135deg, var(--teal-bright), var(--sky));
    box-shadow: 0 12px 40px -8px rgba(154, 163, 176, 0.6);
    padding-left: 4px;
  }
  .soon {
    font-size: 0.92rem;
    color: var(--text-soft);
    background: rgba(0, 0, 0, 0.45);
    padding: 5px 12px;
    border-radius: 999px;
    backdrop-filter: blur(6px);
  }
</style>
