---
import { pricing, site } from '../config';
const isLive = pricing.status === 'live' && pricing.price;
---

<section id="pricing">
  <div class="container">
    <div class="head reveal">
      <span class="eyebrow">Pricing</span>
      <h2 class="section-title">{isLive ? 'One simple license.' : 'Pricing is on the way.'}</h2>
      <p class="section-sub">
        {
          isLive
            ? `Buy once, own it. ${site.name} is a focused tool with a price to match.`
            : `${site.name} is in active development and builds aren't public yet. Paid licenses launch soon — drop your email to get launch pricing and a heads-up.`
        }
      </p>
    </div>

    <div class="card glass reveal">
      <div class="card-glow" aria-hidden="true"></div>

      <div class="price-row">
        {
          isLive ? (
            <span class="price">{pricing.price}</span>
          ) : (
            <span class="price soon">Coming&nbsp;soon</span>
          )
        }
        <span class="price-note">{isLive ? 'one-time' : 'launching soon'}</span>
      </div>

      <ul class="perks">
        {
          pricing.perks.map((p) => (
            <li>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M20 6 9 17l-5-5" />
              </svg>
              {p}
            </li>
          ))
        }
      </ul>

      {
        isLive ? (
          <a class="btn btn-primary full" href="/#download">
            Get {site.name}
          </a>
        ) : (
          <form class="waitlist" data-waitlist>
            <input
              type="email"
              name="email"
              required
              placeholder="you@example.com"
              aria-label="Email address"
            />
            <button class="btn btn-primary" type="submit">Notify me</button>
          </form>
        )
      }
      {!isLive && <p class="micro">No spam — just a single email when licenses go live.</p>}
    </div>
  </div>
</section>

<script>
  // Waitlist: opens the user's mail client pre-addressed. Swap this for a real
  // form endpoint (Formspree, ConvertKit, Buttondown…) when you're ready.
  import { site } from '../config';
  const form = document.querySelector<HTMLFormElement>('[data-waitlist]');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const email = new FormData(form).get('email')?.toString().trim() ?? '';
    const subject = encodeURIComponent(`Notify me when ${site.name} licenses launch`);
    const body = encodeURIComponent(`Please add me to the launch list.\n\nMy email: ${email}`);
    window.location.href = `mailto:${site.contactEmail}?subject=${subject}&body=${body}`;
  });
</script>

<style>
  .head {
    text-align: center;
    margin-inline: auto;
    max-width: 620px;
    margin-bottom: 44px;
  }
  .head .section-sub {
    margin-inline: auto;
  }
  .card {
    position: relative;
    overflow: hidden;
    max-width: 460px;
    margin-inline: auto;
    padding: 40px 32px;
    text-align: center;
  }
  .card-glow {
    position: absolute;
    inset: -50% 0 auto;
    height: 260px;
    background: radial-gradient(50% 100% at 50% 0%, rgba(174, 182, 194, 0.28), transparent 70%);
    filter: blur(40px);
    pointer-events: none;
  }
  .price-row {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    margin-bottom: 28px;
  }
  .price {
    font-size: clamp(2.4rem, 6vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    background: linear-gradient(120deg, #fff, var(--violet-bright));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .price-note {
    font-size: 0.85rem;
    color: var(--text-muted);
  }
  .perks {
    position: relative;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-align: left;
    margin-bottom: 28px;
  }
  .perks li {
    display: flex;
    align-items: center;
    gap: 11px;
    color: var(--text-soft);
    font-size: 0.95rem;
  }
  .perks svg {
    color: var(--green);
    flex-shrink: 0;
  }
  .full {
    width: 100%;
    justify-content: center;
  }
  .waitlist {
    position: relative;
    display: flex;
    gap: 9px;
  }
  .waitlist input {
    flex: 1;
    min-width: 0;
    padding: 0.8em 1em;
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    background: rgba(0, 0, 0, 0.3);
    color: var(--text);
    font-size: 0.95rem;
    font-family: inherit;
  }
  .waitlist input:focus {
    outline: none;
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(174, 182, 194, 0.25);
  }
  .waitlist input::placeholder {
    color: var(--text-muted);
  }
  .micro {
    position: relative;
    margin-top: 14px;
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  @media (max-width: 460px) {
    .waitlist {
      flex-direction: column;
    }
    .waitlist .btn {
      justify-content: center;
    }
  }
</style>
