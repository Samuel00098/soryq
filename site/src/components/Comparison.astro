---
import { comparison as c } from '../config';
---

<section id="compare">
  <div class="container">
    <div class="head reveal">
      <span class="eyebrow">How it stacks up</span>
      <h2 class="section-title">Native speed, a fraction of the memory.</h2>
    </div>

    <div class="table glass reveal" role="table" aria-label="Feature comparison">
      <div class="row row-head" role="row">
        <div class="cell label" role="columnheader"></div>
        {
          c.cols.map((col, i) => (
            <div class={`cell ${i === 0 ? 'is-soryq' : ''}`} role="columnheader">
              {col}
            </div>
          ))
        }
      </div>
      {
        c.rows.map((r) => (
          <div class="row" role="row">
            <div class="cell label" role="rowheader">
              {r.label}
            </div>
            {r.values.map((v, i) => (
              <div class={`cell ${i === r.win ? 'win' : ''}`} role="cell">
                {i === r.win && (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                )}
                {v}
              </div>
            ))}
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .head {
    text-align: center;
    margin-bottom: 48px;
  }
  .table {
    overflow: hidden;
    padding: 0;
  }
  .row {
    display: grid;
    grid-template-columns: 1.3fr 1fr 1fr 1fr;
    border-bottom: 1px solid var(--glass-border);
  }
  .row:last-child {
    border-bottom: none;
  }
  .cell {
    padding: 16px 18px;
    font-size: 0.92rem;
    display: flex;
    align-items: center;
    gap: 7px;
    color: var(--text-soft);
  }
  .cell.label {
    font-weight: 600;
    color: var(--text);
  }
  .row-head .cell {
    font-weight: 700;
    color: var(--text);
    font-size: 0.95rem;
    background: rgba(255, 255, 255, 0.03);
  }
  .row-head .is-soryq {
    color: var(--violet-bright);
  }
  .cell.win {
    color: var(--text);
    font-weight: 600;
  }
  .cell.win svg {
    color: var(--green);
    flex-shrink: 0;
  }
  /* Highlight the Soryq column */
  .row > .cell:nth-child(2) {
    background: linear-gradient(180deg, rgba(45, 212, 191, 0.12), rgba(56, 189, 248, 0.04));
  }
  @media (max-width: 720px) {
    .table {
      overflow-x: auto;
    }
    .row {
      grid-template-columns: 130px 110px 110px 110px;
      min-width: 460px;
    }
    .cell {
      padding: 13px 14px;
      font-size: 0.85rem;
    }
  }
</style>
