---
import { features } from '../config';
// Bento spans — first tile is the large featured one; index 3 is a full-width
// banner (the AI / bring-your-own-key tile). Keeps the 6-col grid filling cleanly
// across 4 rows: big(4x2)+2 smalls, full-width banner, then a row of 3 smalls.
const spans = ['big', '', '', 'full', '', '', ''];
---

<section id="features">
  <div class="container">
    <div class="head reveal">
      <span class="eyebrow">Everything in one window</span>
      <h2 class="section-title">A whole workflow, no tab-hopping.</h2>
      <p class="section-sub">
        Terminal, editor, preview, and Git — unified and keyboard-driven, so you stay in flow
        instead of juggling apps.
      </p>
    </div>

    <div class="bento">
      {
        features.map((f, i) => (
          <article class={`tile glass reveal ${spans[i] ?? ''}`} style={`--c:${f.accent}`}>
            <span class="glyph" aria-hidden="true" />
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .head {
    text-align: center;
    margin-inline: auto;
    max-width: 640px;
    margin-bottom: 56px;
  }
  .head .section-sub {
    margin-inline: auto;
  }

  /* Bento: 6 columns, auto rows. Featured tile spans 2x2; one wide tile spans 2 cols. */
  .bento {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    grid-auto-rows: minmax(168px, auto);
    gap: 18px;
  }
  .tile {
    grid-column: span 2;
    padding: 26px 24px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }
  .tile:hover {
    transform: translateY(-4px);
    border-color: var(--glass-border-strong);
  }
  .tile.big {
    grid-column: span 4;
    grid-row: span 2;
    justify-content: flex-end;
  }
  .tile.wide {
    grid-column: span 4;
  }
  /* Full-width banner tile (AI / bring-your-own-key) */
  .tile.full {
    grid-column: span 6;
    background:
      radial-gradient(90% 140% at 100% 0%, rgba(154, 163, 176, 0.14), transparent 55%),
      radial-gradient(70% 140% at 0% 100%, rgba(174, 182, 194, 0.12), transparent 55%),
      var(--glass-bg);
  }
  .tile.full h3 {
    font-size: 1.32rem;
  }
  .tile.full p {
    max-width: 70ch;
  }

  /* Featured tile gets an animated gradient ring + bloom */
  .tile.big {
    background:
      radial-gradient(120% 90% at 0% 0%, rgba(174, 182, 194, 0.16), transparent 55%),
      var(--glass-bg);
  }
  .tile.big::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1px;
    background: conic-gradient(
      from 180deg,
      transparent 0deg,
      var(--violet) 90deg,
      var(--cyan) 180deg,
      transparent 300deg
    );
    -webkit-mask:
      linear-gradient(#000 0 0) content-box,
      linear-gradient(#000 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0.55;
    animation: spin 8s linear infinite;
  }
  @keyframes spin {
    to {
      transform: rotate(1turn);
    }
  }

  .glyph {
    width: 30px;
    height: 30px;
    border-radius: 9px;
    margin-bottom: 16px;
    background: color-mix(in srgb, var(--c) 22%, transparent);
    border: 1px solid color-mix(in srgb, var(--c) 45%, transparent);
    box-shadow: 0 0 22px -6px var(--c);
    position: relative;
  }
  .glyph::after {
    content: '';
    position: absolute;
    inset: 8px;
    border-radius: 4px;
    background: var(--c);
    opacity: 0.85;
  }
  .tile.big .glyph {
    width: 38px;
    height: 38px;
  }
  .tile h3 {
    font-size: 1.12rem;
    font-weight: 600;
    margin-bottom: 9px;
    letter-spacing: -0.01em;
    position: relative;
  }
  .tile.big h3 {
    font-size: 1.5rem;
  }
  .tile p {
    color: var(--text-soft);
    font-size: 0.95rem;
    position: relative;
  }

  @media (max-width: 880px) {
    .bento {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: auto;
    }
    .tile,
    .tile.big,
    .tile.wide,
    .tile.full {
      grid-column: span 1;
      grid-row: auto;
    }
    .tile.big,
    .tile.full {
      grid-column: span 2;
    }
  }
  @media (max-width: 540px) {
    .bento {
      grid-template-columns: 1fr;
    }
    .tile.big,
    .tile.full {
      grid-column: span 1;
    }
  }
</style>
