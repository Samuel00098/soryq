---
import '../styles/global.css';
import { site } from '../config';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = site.description } = Astro.props;
const fullTitle = title ? `${title} — ${site.name}` : `${site.name} — ${site.tagline}`;
// Social cards must be a raster image (1200×630) — SVG isn't rendered by
// Twitter/X, Facebook, LinkedIn, Slack, etc. Regenerate from `site/og-source.svg`
// with sharp if the brand art changes.
// Astro.site is always set (see astro.config.mjs — the bound production domain,
// else the live Vercel URL), so this fallback is just a safety net.
const ogImage = new URL('/og.png', Astro.site ?? 'https://site-flame-phi.vercel.app').href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fonts: preconnect first, then one combined stylesheet request. Loading
         them here (rather than via @import in global.css) avoids a serial
         request waterfall; `display=swap` paints fallback text immediately. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=JetBrains+Mono:wght@400;600&display=swap"
    />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} — ${site.tagline}`} />
    <meta property="og:url" content={site.url} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${site.name} — ${site.tagline}`} />
    <meta name="theme-color" content="#07080b" />
  </head>
  <body>
    <!-- Animated mesh-gradient background: large teal/sky/violet blobs that slowly
         morph shape and drift, blending into a living "cool aurora", finished with
         a fine film-grain overlay. All decorative (see global.css). -->
    <div class="site-bg" aria-hidden="true">
      <span class="orb orb-1"></span>
      <span class="orb orb-2"></span>
      <span class="orb orb-3"></span>
      <span class="orb orb-4"></span>
      <span class="beam"></span>
      <span class="grain"></span>
    </div>
    <!-- Futuristic HUD layer: drifting constellation network + holographic
         scanlines, plus a top scroll-progress rail and a corner readout (styles
         in global.css, behaviour in the script below). -->
    <canvas class="fx-net" aria-hidden="true"></canvas>
    <div class="fx-scan" aria-hidden="true"></div>
    <div class="fx-progress" aria-hidden="true"><span></span></div>

    <slot />

    <div class="hud-readout mono" aria-hidden="true">
      <span class="hud-dot"></span> Soryq // v{site.version}
    </div>

    <script>
      // Reveal-on-scroll
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12 },
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // Copy-to-clipboard for command snippets
      document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const text = btn.getAttribute('data-copy') || '';
          try {
            await navigator.clipboard.writeText(text);
            const prev = btn.getAttribute('aria-label') || '';
            btn.classList.add('copied');
            btn.setAttribute('aria-label', 'Copied!');
            setTimeout(() => {
              btn.classList.remove('copied');
              btn.setAttribute('aria-label', prev);
            }, 1400);
          } catch {
            /* clipboard unavailable */
          }
        });
      });

      // Top scroll-progress rail
      const progress = document.querySelector<HTMLElement>('.fx-progress > span');
      if (progress) {
        const onScroll = () => {
          const doc = document.documentElement;
          const max = doc.scrollHeight - doc.clientHeight;
          progress.style.width = `${max > 0 ? Math.min(100, (doc.scrollTop / max) * 100) : 0}%`;
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll);
        onScroll();
      }

      // Constellation network — drifting nodes linked by faint lines, with a
      // gentle parallax toward the cursor. Capped node count + paired distance
      // checks keep it light; it pauses when the tab is hidden and renders a
      // single static frame under prefers-reduced-motion.
      const canvas = document.querySelector<HTMLCanvasElement>('.fx-net');
      const ctx = canvas?.getContext('2d');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      // Touch / small screens get a single static frame instead of the looping
      // constellation: the rAF loop is the heaviest main-thread cost and matters
      // least on phones, where smoothness and battery win over the effect.
      const lowPower =
        window.matchMedia('(pointer: coarse)').matches || window.innerWidth < 760;
      if (canvas && ctx) {
        const LINK = 132; // px distance under which two nodes connect
        const CURSOR = 168; // px radius the cursor links to nearby nodes
        let w = 0;
        let h = 0;
        let dpr = 1;
        let pts: { x: number; y: number; vx: number; vy: number }[] = [];
        const mouse = { x: -9999, y: -9999 };
        let ox = 0;
        let oy = 0;
        let raf = 0;

        const resize = () => {
          w = window.innerWidth;
          h = window.innerHeight;
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          canvas.width = Math.round(w * dpr);
          canvas.height = Math.round(h * dpr);
          ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
          const count = Math.max(28, Math.min(92, Math.round((w * h) / 19000)));
          pts = Array.from({ length: count }, () => ({
            x: Math.random() * w,
            y: Math.random() * h,
            vx: (Math.random() - 0.5) * 0.24,
            vy: (Math.random() - 0.5) * 0.24,
          }));
        };

        const draw = (animate: boolean) => {
          // ease the parallax offset toward the cursor (skip when static)
          if (animate) {
            const tx = mouse.x < 0 ? 0 : (mouse.x - w / 2) * 0.018;
            const ty = mouse.y < 0 ? 0 : (mouse.y - h / 2) * 0.018;
            ox += (tx - ox) * 0.05;
            oy += (ty - oy) * 0.05;
          }
          ctx.clearRect(0, 0, w, h);
          ctx.save();
          ctx.translate(ox, oy);

          for (const p of pts) {
            if (animate) {
              p.x += p.vx;
              p.y += p.vy;
              if (p.x < -20) p.x = w + 20;
              else if (p.x > w + 20) p.x = -20;
              if (p.y < -20) p.y = h + 20;
              else if (p.y > h + 20) p.y = -20;
            }
          }

          // links between nearby nodes
          for (let i = 0; i < pts.length; i++) {
            for (let j = i + 1; j < pts.length; j++) {
              const dx = pts[i].x - pts[j].x;
              const dy = pts[i].y - pts[j].y;
              const d2 = dx * dx + dy * dy;
              if (d2 < LINK * LINK) {
                const a = (1 - Math.sqrt(d2) / LINK) * 0.5;
                ctx.strokeStyle = `rgba(45, 212, 191, ${a})`;
                ctx.lineWidth = 1;
                ctx.beginPath();
                ctx.moveTo(pts[i].x, pts[i].y);
                ctx.lineTo(pts[j].x, pts[j].y);
                ctx.stroke();
              }
            }
          }

          // brighter links from the cursor to nearby nodes
          if (mouse.x >= 0) {
            const mx = mouse.x - ox;
            const my = mouse.y - oy;
            for (const p of pts) {
              const dx = p.x - mx;
              const dy = p.y - my;
              const d2 = dx * dx + dy * dy;
              if (d2 < CURSOR * CURSOR) {
                const a = (1 - Math.sqrt(d2) / CURSOR) * 0.5;
                ctx.strokeStyle = `rgba(56, 189, 248, ${a})`;
                ctx.lineWidth = 1;
                ctx.beginPath();
                ctx.moveTo(mx, my);
                ctx.lineTo(p.x, p.y);
                ctx.stroke();
              }
            }
          }

          // nodes
          ctx.fillStyle = 'rgba(125, 211, 252, 0.7)';
          for (const p of pts) {
            ctx.beginPath();
            ctx.arc(p.x, p.y, 1.3, 0, Math.PI * 2);
            ctx.fill();
          }
          ctx.restore();
        };

        const loop = () => {
          draw(true);
          raf = requestAnimationFrame(loop);
        };
        const start = () => {
          if (!raf) loop();
        };
        const stop = () => {
          if (raf) cancelAnimationFrame(raf);
          raf = 0;
        };

        resize();
        window.addEventListener('resize', () => {
          resize();
          if (reduceMotion || lowPower) draw(false);
        });
        window.addEventListener(
          'pointermove',
          (e) => {
            mouse.x = e.clientX;
            mouse.y = e.clientY;
          },
          { passive: true },
        );
        window.addEventListener('pointerleave', () => {
          mouse.x = -9999;
          mouse.y = -9999;
        });
        document.addEventListener('visibilitychange', () => {
          if (document.hidden) stop();
          else if (!reduceMotion && !lowPower) start();
        });

        if (reduceMotion || lowPower) {
          draw(false); // one static frame, no rAF loop
        } else if ('requestIdleCallback' in window) {
          // Defer the animation until the main thread is idle so it never
          // competes with first paint / hydration during initial load.
          requestIdleCallback(start, { timeout: 1200 });
        } else {
          start();
        }
      }
    </script>
  </body>
</html>
